#!/bin/sh
# Pre-commit hook — rustfmt + clippy gate (WEG-35 / DR-007).
#
# Mirrors the CI lint checks so formatting / clippy drift is caught locally
# before it can turn main red (recurrence fix for WEG-255). Commands are kept
# byte-identical to .github/workflows/ci.yml.
#
# Installed per clone via:  git config core.hooksPath .githooks
set -eu

echo "pre-commit: cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "pre-commit: cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings
